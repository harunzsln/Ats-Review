# Supabase
SUPABASE_URL=http://localhost:54321
# Publishable / anon key — used with the end-user JWT (RLS enforced).
SUPABASE_ANON_KEY=your-anon-key
# Service role key — ONLY for admin ops (account hard-delete). Never sent to clients.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT secret used to verify Supabase access tokens (Project Settings > API > JWT secret).
SUPABASE_JWT_SECRET=your-jwt-secret

# Storage
CV_BUCKET=cv-files
SIGNED_URL_TTL_SECONDS=120

# Google Gemini
# Models (June 2026): gemini-2.5-flash (default), gemini-2.5-flash-lite, gemini-2.5-pro
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# KVKK disclosure text version currently in force.
KVKK_DISCLOSURE_VERSION=2026-01-01

# CORS
FRONTEND_ORIGIN=http://localhost:3000
